{
  "name": "react-library-boilerplate",
  "description": "A minimal Vite-based boilerplate for TypeScript React libraries with components, hooks, and utilities. Styled with Sass and includes a demo inside src/ — no Storybook included.",
  "private": false,
  "author": "Aleksandra Mętrak",
  "license": "MIT",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/main.js",
  "module": "./dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b ./tsconfig.lib.json && vite build",
    "watch": "tsc -b ./tsconfig.lib.json --watch & vite build --watch",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "unplugin-dts": "^1.0.1",
    "vite": "^8.0.14",
    "vite-plugin-lib-inject-css": "^2.2.2"
  }
}
